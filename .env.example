# HistoryOS environment variables.
# Copy this file to `.env` and fill in the real values.
# `.env` holds secrets and should never be committed.

# --- Required secrets ---------------------------------------------------------
# Cerebras API key — powers ALL LLM calls (free, OpenAI-compatible API).
CEREBRAS_API_KEY=csk-your-cerebras-key-here

# OpenRouter API key — fallback provider for when Cerebras hits its daily
# token quota. Free tier available at https://openrouter.ai.
OPENROUTER_API_KEY=your_key_here

# OpenAI API key — NOT needed. LLM calls go to Cerebras and embeddings are local
# (sentence-transformers). Left commented only as a reminder; safe to omit.
# OPENAI_API_KEY=

# Tavily API key — used for web search augmentation in the retrieval engine.
# Optional: leave blank to disable web fallback.
TAVILY_API_KEY=tvly-your-tavily-key-here

# --- Models (override only if you know why) -----------------------------------
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=gpt-oss-120b
# Local sentence-transformers model (384-token window); no API key, runs on torch.
EMBEDDING_MODEL=all-mpnet-base-v2
LLM_TEMPERATURE=0.0

# --- Vector store (ChromaDB) --------------------------------------------------
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=historios

# --- Ingestion / chunking -----------------------------------------------------
CHUNK_SIZE=300
CHUNK_OVERLAP=100

# --- Retrieval ----------------------------------------------------------------
TOP_K=5

# --- Reasoning guardrails -----------------------------------------------------
# Critical Rule #3: max 4 causal reasoning steps (hallucination guard).
MAX_CAUSAL_STEPS=4
